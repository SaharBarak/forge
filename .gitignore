dist/
dist-electron/

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Logs
*.log
npm-debug.log*

# Output (keep structure, ignore content)
output/sessions/*
output/drafts/*
output/final/*
output/forge-landing-copy/runs/
output/forge-landing-copy/latest
output/forge-landing-copy/*.md
!output/sessions/.gitkeep
!output/drafts/.gitkeep
!output/final/.gitkeep

