# Forge — will-it-work mode demo
# Output: docs/demo/will-it-work.gif

Output docs/demo/will-it-work.gif

Set Theme "Catppuccin Mocha"
Set FontSize 13
Set Width 1100
Set Height 680
Set Padding 22
Set FontFamily "JetBrains Mono"
Set TypingSpeed 30ms

Type "clear && npx tsx scripts/forge-landing-copy.ts"
Sleep 600ms
Enter
Sleep 60s
